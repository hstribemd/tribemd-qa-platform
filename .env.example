# Login Keycloak (auth.tribemd.com). Copie para .env e preencha. NAO versione o .env.
# Use SEMPRE uma conta de TESTE dedicada — nunca uma conta pessoal/real.
AUTH_USER=email-da-conta-de-teste@tribemd.com
AUTH_PASS=senha-da-conta-de-teste

# Opcionais — so altere se o site/tema do Keycloak divergir do padrao:
# AUTH_LOGIN_TRIGGER=text=/entrar|login|acessar/i   # botao "Entrar" no site
# AUTH_USER_SELECTOR=#username                       # campo e-mail no Keycloak
# AUTH_PASS_SELECTOR=#password
# AUTH_SUBMIT_SELECTOR=#kc-login
# AUTH_HOST=auth.tribemd.com
# AUTH_LOGGEDIN_SELECTOR=[data-testid="user-menu"]   # elemento visivel so logado

# Rotas logadas a validar no Caso 1 (suite 'authenticated'), separadas por virgula:
# AUTH_ROUTES=/br/perfil/19/,/br/connect/
